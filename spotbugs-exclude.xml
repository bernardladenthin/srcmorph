<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/4.8.6/spotbugs/etc/findbugsfilter.xsd">

    <!--
        HelpMojo is generated by maven-plugin-plugin from plugin.xml. The DocumentBuilder.parse()
        call inside it is not under project control, and the generated class triggers the
        fb-contrib IMC family (no toString, instance fields before static fields) which we
        cannot fix on our side without forking the generator. Suppressing the full set of
        generated-source lint patterns for this class only.
    -->
    <Match>
        <Class name="net.ladenthin.llamacpp_ai_index_maven_plugin.HelpMojo"/>
        <Or>
            <Bug pattern="XXE_DOCUMENT"/>
            <Bug pattern="IMC_IMMATURE_CLASS_NO_TOSTRING"/>
            <Bug pattern="IMC_IMMATURE_CLASS_WRONG_FIELD_ORDER"/>
        </Or>
    </Match>

    <!--
        IMC_IMMATURE_CLASS_NO_EQUALS on Maven plugin Mojos.

        AbstractAiIndexMojo and its concrete subclasses (GenerateMojo,
        AggregatePackagesMojo) are Maven Mojo instances. Maven instantiates one
        per execution via reflection, populates @Parameter fields via setter
        injection, calls execute(), then discards the instance. Mojos are
        managed by identity (Maven keeps no map keyed on a Mojo instance), and
        no project code compares two Mojos for value equality.

        Generating a value-equality equals here would:
          - Not change runtime behaviour (no caller compares Mojos by value).
          - Create a false impression that Mojos are value objects, encouraging
            future readers to put them in Sets/Maps where the mutable @Parameter
            fields would silently break the invariants.
          - Need a callSuper=true chain through AbstractMojo (which extends
            Object directly and has no fields that participate in equality), so
            the generated method would just be (this == that) wrapped in a
            field-by-field comparison of plugin-injected @Parameter values.

        Identity equality (the default from Object) is the correct semantics
        for a Maven Mojo.
    -->
    <Match>
        <Or>
            <Class name="net.ladenthin.maven.llamacpp.aiindex.AbstractAiIndexMojo"/>
            <Class name="net.ladenthin.maven.llamacpp.aiindex.AggregatePackagesMojo"/>
            <Class name="net.ladenthin.maven.llamacpp.aiindex.GenerateMojo"/>
        </Or>
        <Bug pattern="IMC_IMMATURE_CLASS_NO_EQUALS"/>
    </Match>

    <!--
        IMC_IMMATURE_CLASS_NO_EQUALS on Maven @Parameter configuration POJOs.

        AiFieldGenerationConfig and AiPromptDefinition are mutable JavaBean
        POJOs that the Maven plugin framework instantiates via reflection,
        populates through setters, and stores in a List<...> @Parameter field
        on the parent Mojo. No code path compares two instances for value
        equality; the surrounding Mojo iterates the list in source order and
        uses the (non-null) string keys (promptKey, aiDefinitionKey,
        AiPromptDefinition.key) to drive lookups against the other registries.

        Generating a value-equality equals over their mutable fields would:
          - Mislead readers into thinking these are immutable value types.
          - Make Set/Map semantics dependent on the Maven framework's
            population order (the values are mutable until setter injection
            completes).
          - Force a reciprocal hashCode that violates the immutability
            assumption hashCode contracts depend on.

        Identity is the correct semantics for a Maven @Parameter JavaBean.
    -->
    <Match>
        <Or>
            <Class name="net.ladenthin.maven.llamacpp.aiindex.AiFieldGenerationConfig"/>
            <Class name="net.ladenthin.maven.llamacpp.aiindex.AiPromptDefinition"/>
        </Or>
        <Bug pattern="IMC_IMMATURE_CLASS_NO_EQUALS"/>
    </Match>

    <!--
        IMC_IMMATURE_CLASS_NO_EQUALS on the AiModelDefinitionSupport service.

        AiModelDefinitionSupport is a service/lookup class: it owns a
        Map<String, AiGenerationConfig> built once from the @Parameter
        definitions list, and exposes a get(key) lookup. It is constructed
        once per Mojo execution, held inside the Mojo, and discarded. No
        code path stores two AiModelDefinitionSupport instances in a Set/Map
        keyed by value, and the underlying map is mutable by design (Maven
        plugin framework populates the source list of definitions via
        reflection during Mojo configuration).

        Identity is the correct semantics for a stateful service object.
    -->
    <Match>
        <Class name="net.ladenthin.maven.llamacpp.aiindex.AiModelDefinitionSupport"/>
        <Bug pattern="IMC_IMMATURE_CLASS_NO_EQUALS"/>
    </Match>

</FindBugsFilter>

<!--
    Example Logback configuration for srcmorph-cli. Drop a copy on the classpath, or point at it
    via -Dlogback.configurationFile=<path>, to override the bundled default logback binding shipped
    inside the fat jar. Console-only, INFO level - suitable as a starting point for local runs.
-->
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
